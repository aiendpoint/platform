{
  "name": "aiendpoint-platform",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "web:dev": "pnpm --filter web dev",
    "web:build": "pnpm --filter web build",
    "web:start": "pnpm --filter web start",
    "demo:news": "cd demos/news && node index.js",
    "demo:weather": "cd demos/weather && uvicorn main:app --port 3002",
    "demo:fx": "cd demos/fx && wrangler dev --port 3003"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp@>=8.0.0 <8.4.0": "8.4.0",
      "path-to-regexp@<0.1.13": "0.1.13",
      "hono@<4.12.14": "4.12.14",
      "@hono/node-server@<1.19.13": "1.19.13",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
